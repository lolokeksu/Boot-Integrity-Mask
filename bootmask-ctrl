  msg "${CYAN}СИСТЕМА ХУКОВ${NC}"
  msg "  ${GREEN}hooks list${NC}        — показать все установленные хуки"
  msg "  ${GREEN}hooks run <событие>${NC} — принудительно запустить хуки"
  msg "                         для указанного события (для тестирования)"
  msg ""
  msg "${CYAN}СОВЕТЫ ПО ИСПОЛЬЗОВАНИЮ${NC}"
  msg "  • При первом запуске выполните ${GREEN}analyze${NC} — он проверит всё"
  msg "    и подскажет, что нужно исправить."
  msg "  • Если после установки модуля пропали другие разделы"
  msg "    в /dev/block/by-name, включите ${GREEN}compatibility-mode on${NC}."
  msg "  • Для максимальной скрытности используйте ${GREEN}stealth on${NC}."
  msg "  • Watchdog настраивается в файле"
  msg "    ${GREEN}/data/adb/modules/bootmask/common/watchdog.conf${NC}"
  msg "    (первая строка — интервал в секундах, вторая — 'debug')."
  msg "  • Все бекапы и отчёты хранятся в ${GREEN}/sdcard/BootMask/${NC}."
  msg ""
  msg "${CYAN}ГОРЯЧИЕ КЛАВИШИ В МЕНЮ${NC}"
  msg "  s,e,d,r,w,l,c,i,g,p,m,f,t,x,o,a,hk,hr,ld — быстрый выбор пунктов"
  msg "  y/n/s/q — переключение режимов в интерактивных переключателях"
  msg ""
}

interactive_menu() {
  check_deps
  while true; do
    show_dashboard
    msg ""
    status_line
    msg ""

    msg "${GREEN}• ИНФОРМАЦИЯ И ДИАГНОСТИКА${NC}"
    msg "  ${GREEN}1)${NC} status               ${GREEN}2)${NC} logs       ${GREEN}3)${NC} check-integrity"
    msg "  ${GREEN}4)${NC} image-info           ${GREEN}5)${NC} diag       ${GREEN}6)${NC} analyze"
    msg ""

    msg "${YELLOW}• УПРАВЛЕНИЕ МОДУЛЕМ${NC}"
    msg "  ${YELLOW}7)${NC} enable               ${YELLOW}8)${NC} disable    ${RED}9)${NC} restore"
    msg "  ${YELLOW}10)${NC} restart-watchdog    ${YELLOW}11)${NC} freeze     ${YELLOW}12)${NC} thaw"
    msg ""

    msg "${CYAN}• РЕЖИМЫ РАБОТЫ${NC}"
    msg "  ${CYAN}13)${NC} compatibility-mode   ${CYAN}14)${NC} stealth    ${CYAN}15)${NC} monitor"
    msg ""

    msg "${BLUE}• ОТЧЁТЫ${NC}"
    msg "  ${BLUE}16)${NC} report               ${BLUE}17)${NC} diff-report"
    msg ""

    msg "${MAGENTA}• ХУКИ${NC}"
    msg "  ${MAGENTA}18)${NC} hooks list          ${MAGENTA}19)${NC} hooks run <event>"
    msg ""

    msg "  ${RED}0)${NC} exit"
    msg ""

    msg "Горячие клавиши: s,e,d,r,w,l,c,i,g,p,m,f,t,x,o,a,hk,hr,ld  (или номер)"
    printf "Ваш выбор: "
    read choice
    local lower_choice=$(echo "$choice" | tr -d '\n\r' | tr 'A-Z' 'a-z')

    local CMD="" subopt="" subcmd=""
    case "$lower_choice" in
      s|1) CMD="status" ;;
      l|2) CMD="logs" ;;
      c|3) CMD="check-integrity" ;;
      i|4) CMD="image-info" ;;
      g|5) CMD="diag" ;;
      a|6) CMD="analyze" ;;
      e|7) CMD="enable" ;;
      d|8) CMD="disable" ;;
      r|9) CMD="restore" ;;
      w|10) CMD="restart-watchdog" ;;
      f|11) CMD="freeze" ;;
      t|12) CMD="thaw" ;;
      m|13) CMD="compatibility-mode"; subopt="" ;;
      x|14) CMD="stealth"; subopt="" ;;
      o|15) CMD="monitor"; subopt="" ;;
      p|16) CMD="report" ;;
      ld|17) CMD="diff-report" ;;
      hk|18) CMD="hooks"; subcmd="list" ;;
      hr|19) CMD="hooks"; subcmd="run"; printf "Введите событие: "; read subopt ;;
      0|exit)
        if [ ! -f "$DISABLE_FLAG" ]; then
          printf "Модуль активен. Выйти? [y/N] "
          read yn
          case "$yn" in
            [Yy]|[Yy][Ee][Ss]) msg "Выход."; exit 0 ;;
            *) continue ;;
          esac
        else
          msg "Выход."; exit 0
        fi
        ;;
      *) msg "${RED}Неверный выбор${NC}"; sleep 1; continue ;;
    esac

    case "$CMD" in
      compatibility-mode|stealth|monitor)
        local current_state="ВЫКЛ"
        case "$CMD" in
          compatibility-mode) [ -f "$COMPAT_FLAG" ] && current_state="ВКЛ" ;;
          stealth) [ -f "$STEALTH_FLAG" ] && current_state="ВКЛ" ;;
          monitor) [ -f "$MONITOR_FLAG" ] && current_state="ВКЛ" ;;
        esac
        while true; do
          msg ""
          msg "Режим: ${CYAN}${CMD}${NC}   (сейчас: $([ "$current_state" = "ВКЛ" ] && echo -e "${YELLOW}ВКЛ${NC}" || echo "ВЫКЛ"))"
          msg "  [${GREEN}y${NC}] Включить"
          msg "  [${RED}n${NC}] Выключить"
          msg "  [${BLUE}s${NC}] Статус"
          msg "  [${YELLOW}q${NC}] Отмена"
          printf "Выбор (y/n/s/q): "
          read subopt
          local lower_sub=$(echo "$subopt" | tr -d '\n\r' | tr 'A-Z' 'a-z')
          case "$lower_sub" in
            y) subopt="on"; break ;;
            n) subopt="off"; break ;;
            s) subopt="status"; break ;;
            q|*) subopt=""; break ;;
          esac
        done
        ;;
    esac

    if [ -n "$CMD" ]; then
      msg ""
      case "$CMD" in
        status) show_dashboard ;;
        enable) enable_module ;;
        disable) disable_module ;;
        restore) restore_module ;;
        restart-watchdog) restart_watchdog ;;
        logs) show_logs ;;
        check-integrity) check_integrity ;;
        image-info) image_info ;;
        diag) show_diag ;;
        report) generate_report ;;
        compatibility-mode) [ -n "$subopt" ] && handle_compat "$subopt" ;;
        freeze) freeze_module ;;
        thaw) thaw_module ;;
        stealth) [ -n "$subopt" ] && handle_stealth "$subopt" ;;
        monitor) [ -n "$subopt" ] && handle_monitor "$subopt" ;;
        analyze) analyze ;;
        diff-report) diff_report ;;
        hooks) 
          case "$subcmd" in
            list) show_hooks ;;
            run) run_hooks_cmd "$subopt" ;;
          esac
          ;;
      esac
      log_action "menu:$CMD"
    fi
    msg ""
    printf "Нажмите Enter для продолжения..."
    read dummy
  done
}

# --------------------------------------------------------
# Точка входа
# --------------------------------------------------------
if [ $# -ge 1 ]; then
  check_deps
  case "$1" in
    dashboard) show_dashboard ;;
    status)
      if [ "$2" = "--json" ]; then
        show_status_json
      else
        show_dashboard
      fi
      ;;
    enable) enable_module ;;
    disable) disable_module ;;
    restore) restore_module force ;;
    restart-watchdog) restart_watchdog ;;
    logs) show_logs "$2" ;;
    check-integrity) check_integrity ;;
    image-info) image_info ;;
    diag) show_diag ;;
    report) generate_report ;;
    diff-report) diff_report ;;
    compatibility-mode) handle_compat "$2" ;;
    freeze) freeze_module ;;
    thaw) thaw_module ;;
    stealth) handle_stealth "$2" ;;
    monitor) handle_monitor "$2" ;;
    analyze)
      if [ "$2" = "--json" ]; then
        analyze_json
      else
        analyze
      fi
      ;;
    hooks)
      case "$2" in
        list) show_hooks ;;
        run) run_hooks_cmd "$3" ;;
        *) msg "Используйте: hooks list | hooks run <event>" ;;
      esac
      ;;
    help|--help|-h) show_help ;;
    *)
      msg "${RED}Неизвестная команда: $1${NC}"
      msg "Используйте help для списка команд."
      exit 1
      ;;
  esac
else
  interactive_menu
fi