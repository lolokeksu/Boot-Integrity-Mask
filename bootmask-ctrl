# --------------------------------------------------------
# Детекция root-менеджера (мягкая, без жёстких зависимостей)
# --------------------------------------------------------
detect_manager() {
  if [ -d /data/adb/ap ] || [ -f /data/adb/apd ]; then
    echo "APatch"
  elif [ -f /data/adb/ksud ] || [ -d /data/adb/ksu ]; then
    echo "KernelSU"
  elif command -v magisk >/dev/null 2>&1 || [ -d /data/adb/magisk ]; then
    echo "Magisk"
  else
    echo "unknown"
  fi
}

# Потоковый хеш: определяем утилиту один раз, читаем источник ровно один раз
hash_target() {
  local src="$1"
  [ -e "$src" ] || { echo ""; return 1; }
  if command -v sha256sum >/dev/null 2>&1; then
    dd if="$src" bs=1M 2>/dev/null | sha256sum | awk '{print $1}'
  else
    dd if="$src" bs=1M 2>/dev/null | md5sum | awk '{print $1}'
  fi
}

# Список типов разделов, для которых есть активный loop
active_types() {
  local types=""
  [ -n "$(get_active_loop boot)" ] && types="boot"
  for t in $EXTRA_PARTS; do
    [ -f "$MODDIR/.active_${t}_loop" ] && types="$types $t"
  done
  if [ -f "$MODDIR/.super_targets" ]; then
    while IFS= read -r sp; do
      [ -z "$sp" ] && continue
      [ -f "$MODDIR/.active_${sp}_loop" ] && types="$types $sp"
    done < "$MODDIR/.super_targets"
  fi
  echo "$types"
}

# Путь к стоковому образу по типу раздела
stock_img_for() {
  case "$1" in
    boot) echo "$MODDIR/common/stock_boot.img" ;;
    *)    echo "$MODDIR/common/stock_$1.img" ;;
  esac
}

# Путь к активному loop по типу (boot — через get_active_loop, прочие — из файла)
loop_for() {
  case "$1" in
    boot) get_active_loop boot ;;
    *)    cat "$MODDIR/.active_${1}_loop" 2>/dev/null ;;
  esac
}

# --------------------------------------------------------
# check_integrity — сверка всех активных loop со стоковыми образами
# --------------------------------------------------------
check_integrity() {
  msg "${GREEN}=== Проверка целостности ===${NC}\n"
  local types=$(active_types)
  if [ -z "$types" ]; then
    msg "${RED}[!] Нет активных loop-устройств для проверки.${NC}"
    return 1
  fi
  local fails=0 checked=0
  for t in $types; do
    local img=$(stock_img_for "$t")
    local loop=$(loop_for "$t")
    if [ -z "$loop" ] || [ ! -b "$loop" ]; then
      msg "${YELLOW}[i] $t: loop не активен, пропуск.${NC}"
      continue
    fi
    if [ ! -f "$img" ] || [ ! -s "$img" ]; then
      msg "${YELLOW}[i] $t: стоковый образ отсутствует/пуст, пропуск.${NC}"
      continue
    fi
    local sz_img=$(stat -c%s "$img" 2>/dev/null)
    local sz_loop=$(blockdev --getsize64 "$loop" 2>/dev/null)
    checked=$((checked + 1))
    if [ -n "$sz_img" ] && [ -n "$sz_loop" ] && [ "$sz_img" != "$sz_loop" ]; then
      msg "${RED}[!] $t: размеры не совпадают ($sz_img != $sz_loop).${NC}"
      fails=$((fails + 1))
      continue
    fi

    # Кэш хеша образа: если образ не изменился (mtime совпадает) — не читаем заново
    local cache_file="$MODDIR/.integrity_cache_${t}"
    local img_mtime=$(stat -c%Y "$img" 2>/dev/null)
    local h_img=""
    if [ -f "$cache_file" ]; then
      local cached_mtime cached_hash
      IFS=' ' read -r cached_mtime cached_hash < "$cache_file" 2>/dev/null
      if [ "$cached_mtime" = "$img_mtime" ] && [ -n "$cached_hash" ]; then
        h_img="$cached_hash"
        msg "    $t: хеш образа из кэша (образ не менялся)."
      fi
    fi
    if [ -z "$h_img" ]; then
      msg "    $t: вычисление хеша образа..."
      h_img=$(hash_target "$img")
      [ -n "$h_img" ] && printf '%s %s\n' "$img_mtime" "$h_img" > "$cache_file"
    fi

    msg "    $t: вычисление хеша loop..."
    local h_loop=$(hash_target "$loop")
    if [ -n "$h_img" ] && [ "$h_img" = "$h_loop" ]; then
      msg "${GREEN}[✓] $t: целостность подтверждена.${NC}"
    else
      msg "${RED}[!] $t: хеши не совпадают.${NC}"
      msg "       образ: ${h_img:-?}"
      msg "       loop:  ${h_loop:-?}"
      fails=$((fails + 1))
    fi
  done
  msg ""
  if [ "$checked" -eq 0 ]; then
    msg "${YELLOW}=== Нечего проверять. ===${NC}"
  elif [ "$fails" -eq 0 ]; then
    msg "${GREEN}=== Все проверки пройдены ($checked). ===${NC}"
  else
    msg "${RED}=== Несовпадений: $fails из $checked. ===${NC}"
  fi
  log_action "check-integrity (checked=$checked, fails=$fails)"
}

# --------------------------------------------------------
# image_info — размер, хеш, magic для всех stock_*.img
# --------------------------------------------------------
image_info() {
  msg "${GREEN}=== Информация об образах ===${NC}\n"
  local found=0
  for img in "$MODDIR/common/"stock_*.img; do
    [ -f "$img" ] || continue
    [ -s "$img" ] || { msg "${YELLOW}[i] $(basename "$img"): пустой файл, пропуск.${NC}"; continue; }
    found=1
    local name=$(basename "$img")
    local size=$(stat -c%s "$img" 2>/dev/null)
    local magic=$(dd if="$img" bs=8 count=1 2>/dev/null)
    local hash=$(hash_target "$img")
    msg "${CYAN}${name}${NC}"
    msg "    Размер: ${size} байт"
    msg "    Magic:  ${magic}"
    msg "    SHA256: ${hash:-н/д}"
    msg ""
  done
  [ "$found" -eq 0 ] && msg "${YELLOW}[i] Стоковые образы не найдены.${NC}"
  log_action "image-info"
}

# --------------------------------------------------------
# show_logs — объединённый вывод dmesg + bootmask.log
# --------------------------------------------------------
show_logs() {
  local lines="$1"
  case "$lines" in
    ''|*[!0-9]*) lines=50 ;;
  esac
  msg "${GREEN}=== Логи BootMask (dmesg) ===${NC}"
  if command -v dmesg >/dev/null 2>&1; then
    local dout=$(dmesg 2>/dev/null | grep BootMask | tail -n "$lines")
    [ -n "$dout" ] && echo "$dout" || msg "${YELLOW}[i] В dmesg нет записей BootMask.${NC}"
  else
    msg "${YELLOW}[i] dmesg недоступен.${NC}"
  fi
  msg ""
  msg "${GREEN}=== Журнал bootmask.log (последние $lines) ===${NC}"
  if [ -f "$MODDIR/bootmask.log" ]; then
    tail -n "$lines" "$MODDIR/bootmask.log"
  else
    msg "${YELLOW}[i] Файл bootmask.log отсутствует (возможно, stealth или не было событий).${NC}"
  fi
  log_action "logs"
}

# --------------------------------------------------------
# show_diag — расширенная текстовая диагностика
# Вызывается также из generate_report.
# --------------------------------------------------------
show_diag() {
  msg "${GREEN}=== Диагностика системы и модуля ===${NC}\n"

  msg "${CYAN}Окружение${NC}"
  msg "    Root-менеджер: $(detect_manager)"
  if command -v getenforce >/dev/null 2>&1; then
    msg "    SELinux: $(getenforce 2>/dev/null)"
  elif [ -f /sys/fs/selinux/enforce ]; then
    local e=$(cat /sys/fs/selinux/enforce 2>/dev/null)
    msg "    SELinux: $([ "$e" = "1" ] && echo Enforcing || echo Permissive)"
  fi
  local slot=$(getprop ro.boot.slot_suffix)
  msg "    Слот: ${slot:-нет (A-only)}"
  msg "    Android: $(getprop ro.build.version.release 2>/dev/null)"
  msg ""

  msg "${CYAN}Утилиты${NC}"
  local missing=""
  for util in losetup blockdev dd stat find readlink md5sum sha256sum mount umount; do
    if command -v "$util" >/dev/null 2>&1; then
      msg "    [✓] $util"
    else
      msg "    ${RED}[!] $util — отсутствует${NC}"
      missing="$missing $util"
    fi
  done
  msg ""

  msg "${CYAN}Состояние${NC}"
  local loop=$(get_active_loop boot)
  msg "    Целевой раздел: $(cat "$MODDIR/.target_part" 2>/dev/null || echo boot)"
  if [ -n "$loop" ] && [ -b "$loop" ]; then
    msg "    [✓] Основной loop: $loop"
  else
    msg "    ${RED}[!] Основной loop не активен${NC}"
  fi

  if [ -f "$MODDIR/.byname_dir" ]; then
    local byname=$(cat "$MODDIR/.byname_dir")
    if grep -q " $byname " /proc/mounts 2>/dev/null; then
      msg "    [✓] tmpfs смонтирована на $byname"
    else
      if [ -f "$COMPAT_FLAG" ]; then
        msg "    [i] tmpfs не используется (compat-режим)"
      else
        msg "    ${RED}[!] tmpfs не смонтирована${NC}"
      fi
    fi
    msg "    by-name доступен: $([ -d "$byname" ] && echo да || echo ${RED}нет${NC})"
  fi

  local nloop=0
  [ -n "$loop" ] && [ -b "$loop" ] && nloop=$((nloop + 1))
  for t in $EXTRA_PARTS; do
    local l=$(cat "$MODDIR/.active_${t}_loop" 2>/dev/null)
    [ -n "$l" ] && [ -b "$l" ] && nloop=$((nloop + 1))
  done

  local free=$(df -k /data 2>/dev/null | tail -1 | awk '{print $4}')
  [ -n "$free" ] && msg "    Свободно в /data: $((free / 1024)) MB"
  msg ""

  msg "${CYAN}Watchdog${NC}"
  local wpid=$(cat "$WATCHDOG_PIDFILE" 2>/dev/null)
  if [ -n "$wpid" ] && kill -0 "$wpid" 2>/dev/null; then
    msg "    [✓] Процесс активен (PID $wpid)"
  else
    msg "    ${YELLOW}[i] Процесс watchdog не обнаружен по PID${NC}"
  fi
  msg "    Stealth: $([ -f "$STEALTH_FLAG" ] && echo ВКЛ || echo ВЫКЛ)"
  msg "    Monitor: $([ -f "$MONITOR_FLAG" ] && echo ВКЛ || echo ВЫКЛ)"
  msg "    Freeze:  $([ -f "$FREEZE_FLAG" ] && echo ВКЛ || echo ВЫКЛ)"

  [ -n "$missing" ] && msg "\n${RED}Внимание: отсутствуют утилиты:${missing}${NC}"
  log_action "diag"
}

# --------------------------------------------------------
# restart_watchdog — корректный перезапуск фонового watchdog
# Защита от гонки: атомарная блокировка через mkdir.
# --------------------------------------------------------
restart_watchdog() {
  local lockdir="$MODDIR/.restart_watchdog.lock"
  if ! mkdir "$lockdir" 2>/dev/null; then
    msg "${YELLOW}Перезапуск watchdog уже выполняется, пропуск.${NC}"
    return 0
  fi

  msg "${GREEN}Перезапуск watchdog...${NC}"
  local old_pid=$(cat "$WATCHDOG_PIDFILE" 2>/dev/null)
  if [ -n "$old_pid" ] && kill -0 "$old_pid" 2>/dev/null; then
    kill "$old_pid" 2>/dev/null
    local n=0
    while kill -0 "$old_pid" 2>/dev/null && [ "$n" -lt 10 ]; do
      sleep 0.3; n=$((n + 1))
    done
    kill -0 "$old_pid" 2>/dev/null && kill -9 "$old_pid" 2>/dev/null
    msg "    Старый процесс (PID $old_pid) остановлен."
  else
    msg "    Активный процесс не найден, выполняется чистый запуск."
  fi
  rm -f "$WATCHDOG_PIDFILE" 2>/dev/null

  if [ -f "$DISABLE_FLAG" ] || [ -f "$FREEZE_FLAG" ]; then
    msg "${YELLOW}Модуль отключён или заморожен — watchdog не запускается.${NC}"
    log_action "restart-watchdog (skipped: disabled/frozen)"
    rmdir "$lockdir" 2>/dev/null
    return 0
  fi

  local svc="$MODDIR/service.sh"
  [ -x "$svc" ] || { msg "${RED}service.sh не найден или не исполняемый.${NC}"; rmdir "$lockdir" 2>/dev/null; return 1; }

  if command -v setsid >/dev/null 2>&1; then
    setsid "$svc" >/dev/null 2>&1 &
  elif command -v nohup >/dev/null 2>&1; then
    nohup "$svc" >/dev/null 2>&1 &
  else
    "$svc" >/dev/null 2>&1 &
  fi

  local n=0 new_pid=""
  while [ "$n" -lt 17 ]; do
    sleep 0.3
    new_pid=$(cat "$WATCHDOG_PIDFILE" 2>/dev/null)
    [ -n "$new_pid" ] && kill -0 "$new_pid" 2>/dev/null && break
    n=$((n + 1))
  done

  if [ -n "$new_pid" ] && kill -0 "$new_pid" 2>/dev/null; then
    msg "${GREEN}Watchdog перезапущен (PID $new_pid).${NC}"
    log_action "restart-watchdog (new pid=$new_pid)"
    rmdir "$lockdir" 2>/dev/null
  else
    msg "${RED}Не удалось подтвердить запуск watchdog.${NC}"
    log_action "restart-watchdog (failed to confirm)"
    rmdir "$lockdir" 2>/dev/null
    return 1
  fi
}

# --------------------------------------------------------
# Обобщённый переключатель флаговых режимов
# --------------------------------------------------------
toggle_flag_mode() {
  local name="$1"
  local flag="$2"
  local action="$3"
  local apply_now="$4"
  case "$action" in
    on)
      if [ -f "$flag" ]; then
        msg "${YELLOW}${name}: уже включён.${NC}"
      else
        touch "$flag"
        if [ "$apply_now" -eq 1 ]; then
          msg "${GREEN}${name}: включён.${NC}"
        else
          msg "${GREEN}${name}: включён. Применится после перезагрузки.${NC}"
        fi
        log_action "${name}:on"
      fi
      ;;
    off)
      if [ -f "$flag" ]; then
        rm -f "$flag"
        if [ "$apply_now" -eq 1 ]; then
          msg "${GREEN}${name}: выключен.${NC}"
        else
          msg "${GREEN}${name}: выключен. Применится после перезагрузки.${NC}"
        fi
        log_action "${name}:off"
      else
        msg "${YELLOW}${name}: уже выключен.${NC}"
      fi
      ;;
    status)
      msg "${name}: $([ -f "$flag" ] && echo -e "${YELLOW}ВКЛ${NC}" || echo "ВЫКЛ")"
      ;;
    *)
      msg "${RED}Используйте: on | off | status${NC}"
      return 1
      ;;
  esac
}

# --------------------------------------------------------
# handle_compat — применяется ПОСЛЕ перезагрузки (живой by-name не трогаем)
# --------------------------------------------------------
handle_compat() {
  local action="$1"
  case "$action" in
    on)
      if [ -f "$COMPAT_FLAG" ] && [ "$(cat "$COMPAT_FLAG" 2>/dev/null | tr -d ' \t\r\n')" = "on" ]; then
        msg "${YELLOW}Compat-режим уже включён.${NC}"
      else
        echo "on" > "$COMPAT_FLAG"
        msg "${GREEN}Compat-режим включён. Применится после перезагрузки.${NC}"
        log_action "compat:on"
      fi
      ;;
    off)
      if [ -f "$COMPAT_FLAG" ]; then
        echo "off" > "$COMPAT_FLAG"
        msg "${GREEN}Compat-режим выключен. Применится после перезагрузки.${NC}"
        log_action "compat:off"
      else
        msg "${YELLOW}Compat-режим уже выключен.${NC}"
      fi
      ;;
    status)
      local st="ВЫКЛ"
      [ -f "$COMPAT_FLAG" ] && [ "$(cat "$COMPAT_FLAG" 2>/dev/null | tr -d ' \t\r\n')" = "on" ] && st="${YELLOW}ВКЛ${NC}"
      msg "Compat-режим: ${st}"
      ;;
    *)
      msg "${RED}Используйте: compatibility-mode on | off | status${NC}"
      return 1
      ;;
  esac
}

