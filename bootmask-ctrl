#!/system/bin/sh
# ========================================================
# Boot Integrity Mask v3.6 – Центр управления
# ========================================================
[ "$(id -u)" -ne 0 ] && echo "Требуются права root" && exit 1

MODDIR="/data/adb/modules/bootmask"
STOCK_PLAIN="$MODDIR/common/stock_boot.img"
DISABLE_FLAG="$MODDIR/disable"
COMPAT_FLAG="$MODDIR/common/compat_mode"
FREEZE_FLAG="$MODDIR/.frozen"
STEALTH_FLAG="$MODDIR/.stealth"
MONITOR_FLAG="$MODDIR/.monitor"
WATCHDOG_PIDFILE="$MODDIR/.watchdog_pid"
HOOKS_DIR="$MODDIR/common/hooks"
CTRL_LOG="$MODDIR/ctrl.log"
RESTORE_COUNT_FILE="$MODDIR/.restore_count"
LOOP_ERROR_FILE="$MODDIR/.loop_error_count"

# Типы дополнительных подменяемых разделов (помимо основного TARGET_PART)
EXTRA_PARTS="vbmeta vendor_boot recovery dtbo"

if [ -t 1 ]; then
  GREEN='\033[0;32m'; RED='\033[0;31m'; YELLOW='\033[1;33m'
  CYAN='\033[0;36m'; BLUE='\033[0;34m'; MAGENTA='\033[0;35m'
  NC='\033[0m'
else
  GREEN=''; RED=''; YELLOW=''; CYAN=''; BLUE=''; MAGENTA=''; NC=''
fi

msg() { echo -e "$1"; }
log_action() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $1" >> "$CTRL_LOG"; }

# Чтение и валидация интервала watchdog (возвращает число или 120 по умолчанию)
get_watchdog_interval() {
  local val
  val=$(head -1 "$MODDIR/common/watchdog.conf" 2>/dev/null | tr -d ' \t\r\n')
  if [ -n "$val" ] && [ "$val" -ge 10 ] 2>/dev/null; then
    echo "$val"
  else
    echo "120"
  fi
}

safe_run() {
  local timeout_sec="$1"; shift
  if command -v timeout >/dev/null 2>&1; then
    timeout "$timeout_sec" "$@" 2>/dev/null
  else
    "$@" 2>/dev/null
  fi
}

check_deps() {
  local missing=""
  for util in losetup blockdev dd stat find readlink md5sum sha256sum; do
    command -v "$util" >/dev/null 2>&1 || missing="$missing $util"
  done
  [ -n "$missing" ] && msg "${RED}[!] Отсутствуют утилиты:${missing}${NC}\n   Некоторые функции меню будут недоступны."
}

CACHED_TEMP="N/A"; CACHED_BATTERY="N/A"; CACHE_TIME=0; CACHE_TTL=2

update_cache() {
  local now=$(date +%s)
  if [ $((now - CACHE_TIME)) -ge $CACHE_TTL ]; then
    [ -f /sys/class/thermal/thermal_zone0/temp ] && CACHED_TEMP=$(( $(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null) / 1000 ))"°C"
    [ -f /sys/class/power_supply/battery/capacity ] && CACHED_BATTERY="$(cat /sys/class/power_supply/battery/capacity)%"
    CACHE_TIME=$now
  fi
}

spinner() {
  local pid=$1
  local chars="/ - \\ |"
  while kill -0 $pid 2>/dev/null; do
    for c in $chars; do
      printf "\r[%c] " "$c"
      sleep 0.1
    done
  done
  printf "\r   \r"
}

get_active_loop() {
  case "$1" in
    boot) cat "$MODDIR/.active_loop" 2>/dev/null ;;
    vbmeta) cat "$MODDIR/.active_vbmeta_loop" 2>/dev/null ;;
    vendor_boot) cat "$MODDIR/.active_vendor_boot_loop" 2>/dev/null ;;
    recovery) cat "$MODDIR/.active_recovery_loop" 2>/dev/null ;;
    dtbo) cat "$MODDIR/.active_dtbo_loop" 2>/dev/null ;;
  esac
}

get_term_width() {
  local w
  if command -v tput >/dev/null 2>&1; then
    w=$(tput cols 2>/dev/null)
  fi
  [ -z "$w" ] && w=$(stty size 2>/dev/null | awk '{print $2}')
  [ -z "$w" ] && w=80
  echo $w
}

show_dashboard() {
  update_cache
  local target=$(cat "$MODDIR/.target_part" 2>/dev/null || echo "boot")
  local loop=$(get_active_loop boot)
  local slot=$(getprop ro.boot.slot_suffix)
  local interval=$(get_watchdog_interval)
  local last_check=$(cat "$MODDIR/.last_check" 2>/dev/null)
  local now=$(date +%s)
  local ago=""
  [ -n "$last_check" ] && ago="$(( now - last_check )) сек. назад"

  local term_width=$(get_term_width)
  if [ "$term_width" -lt 60 ]; then
    msg "=== BOOT INTEGRITY MASK v3.5 ==="
    msg " Статус: $([ -f "$DISABLE_FLAG" ] && echo -e "${RED}ОТКЛЮЧЁН${NC}" || echo -e "${GREEN}АКТИВЕН${NC}")"
    msg " Цель: $target  Loop: ${loop:-нет}"
    msg " Watchdog: ${interval}с  Stealth: $([ -f "$STEALTH_FLAG" ] && echo ВКЛ || echo ВЫКЛ)"
    msg " Compat: $([ -f "$COMPAT_FLAG" ] && echo ВКЛ || echo ВЫКЛ)  Freeze: $([ -f "$FREEZE_FLAG" ] && echo ВКЛ || echo ВЫКЛ)"
    msg " Restores: $(cat "$RESTORE_COUNT_FILE")  Errors: $(cat "$LOOP_ERROR_FILE")"
    msg " Temp: $CACHED_TEMP  Bat: $CACHED_BATTERY"
    if [ -f "$DISABLE_FLAG" ]; then
      msg "${RED}Рекомендации: модуль отключён.${NC}"
    elif [ -z "$loop" ]; then
      msg "${RED}Рекомендации: loop не найден.${NC}"
    else
      msg "${GREEN}Рекомендации: всё работает штатно.${NC}"
    fi
  else
    clear 2>/dev/null || printf "\033[2J\033[H"
    msg "================================================"
    msg "         BOOT INTEGRITY MASK v3.5"
    msg "================================================"
    msg "  Модуль:        $([ -f "$DISABLE_FLAG" ] && echo -e "${RED}ОТКЛЮЧЁН${NC}" || echo -e "${GREEN}АКТИВЕН${NC}")"
    msg "  Целевой раздел: $target"
    msg "  Loop-устройство: ${loop:-нет}"
    msg "  Слот:          ${slot:-нет}"
    msg ""
    msg "  Watchdog:      $([ -f "$MONITOR_FLAG" ] && echo -e "${YELLOW}Мониторинг${NC}" || echo -e "${GREEN}Активен${NC}")"
    msg "    Интервал:    ${interval}с (адаптивный)"
    msg "    Режим:       $([ -f "$MONITOR_FLAG" ] && echo "Только наблюдение" || echo "Восстановление ссылок")"
    msg "    Последняя проверка: ${ago:-нет данных}"
    msg "    Восстановлений: $(cat "$RESTORE_COUNT_FILE")  Ошибок loop: $(cat "$LOOP_ERROR_FILE")"
    msg ""
    msg "  Stealth:       $([ -f "$STEALTH_FLAG" ] && echo -e "${YELLOW}ВКЛ${NC}" || echo "ВЫКЛ")"
    msg "  Monitor:       $([ -f "$MONITOR_FLAG" ] && echo -e "${YELLOW}ВКЛ${NC}" || echo "ВЫКЛ")"
    msg "  Compat mode:   $([ -f "$COMPAT_FLAG" ] && echo -e "${YELLOW}ВКЛ${NC}" || echo "ВЫКЛ")"
    msg "  Freeze:        $([ -f "$FREEZE_FLAG" ] && echo -e "${YELLOW}ВКЛ${NC}" || echo "ВЫКЛ")"
    msg ""
    msg "  Температура:   $CACHED_TEMP"
    msg "  Батарея:       $CACHED_BATTERY"
    msg "================================================"
    if [ -f "$DISABLE_FLAG" ]; then
      msg "  ${RED}Рекомендации: Модуль отключён. Удалите disable и перезагрузитесь.${NC}"
    elif [ -z "$loop" ]; then
      msg "  ${RED}Рекомендации: Loop-устройство не найдено. Выполните restore и перезагрузитесь.${NC}"
    else
      msg "  ${GREEN}Рекомендации: Нет. Всё работает штатно.${NC}"
    fi
    msg "================================================"
  fi
}

status_line() {
  local module_status="АКТИВЕН"
  [ -f "$DISABLE_FLAG" ] && module_status="${RED}ОТКЛЮЧЁН${NC}"
  local interval=$(get_watchdog_interval)
  local stealth="ВЫКЛ"; [ -f "$STEALTH_FLAG" ] && stealth="${YELLOW}ВКЛ${NC}"
  local compat="ВЫКЛ"; [ -f "$COMPAT_FLAG" ] && compat="${YELLOW}ВКЛ${NC}"
  msg "Модуль: ${module_status} | Watchdog: ${interval}с | Stealth: ${stealth} | Compat: ${compat}"
}

show_status_json() {
  local target=$(cat "$MODDIR/.target_part" 2>/dev/null || echo "boot")
  local loop=$(get_active_loop boot)
  local slot=$(getprop ro.boot.slot_suffix)
  local disabled="false"; [ -f "$DISABLE_FLAG" ] && disabled="true"
  local stealth="false"; [ -f "$STEALTH_FLAG" ] && stealth="true"
  local monitor="false"; [ -f "$MONITOR_FLAG" ] && monitor="true"
  local compat="false"; [ -f "$COMPAT_FLAG" ] && compat="true"
  local freeze="false"; [ -f "$FREEZE_FLAG" ] && freeze="true"
  local interval=$(get_watchdog_interval)
  local last_check=$(cat "$MODDIR/.last_check" 2>/dev/null)
  local temp="null"; [ -f /sys/class/thermal/thermal_zone0/temp ] && temp=$(( $(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null) / 1000 ))
  local battery="null"; [ -f /sys/class/power_supply/battery/capacity ] && battery=$(cat /sys/class/power_supply/battery/capacity)
  local restore_count=$(cat "$RESTORE_COUNT_FILE" 2>/dev/null)
  local loop_errors=$(cat "$LOOP_ERROR_FILE" 2>/dev/null)

  echo "{"
  echo "  \"module\": \"${disabled}\","
  echo "  \"disabled\": ${disabled},"
  echo "  \"target\": \"${target}\","
  echo "  \"loop\": \"${loop:-null}\","
  echo "  \"slot\": \"${slot:-null}\","
  echo "  \"watchdog\": {"
  echo "    \"interval\": ${interval},"
  echo "    \"last_check\": \"${last_check:-null}\","
  echo "    \"monitor_mode\": ${monitor},"
  echo "    \"restore_count\": ${restore_count},"
  echo "    \"loop_errors\": ${loop_errors}"
  echo "  },"
  echo "  \"stealth\": ${stealth},"
  echo "  \"compat_mode\": ${compat},"
  echo "  \"frozen\": ${freeze},"
  echo "  \"temperature\": ${temp},"
  echo "  \"battery\": ${battery}"
  echo "}"
}

run_event_hooks() {
  local event="$1"
  local target="$2"
  local loop="$3"
  local link="$4"
  local hook_dir="$HOOKS_DIR/$event"
  [ -d "$hook_dir" ] || return 0
  for script in "$hook_dir"/*; do
    [ -x "$script" ] || continue
    msg "→ Запуск хука: $script (событие: $event)"
    (
      HOOK_EVENT="$event" \
      HOOK_TARGET="$target" \
      HOOK_LOOP="$loop" \
      HOOK_LINK="$link" \
      HOOK_TIMESTAMP=$(date +%s) \
      timeout 30 "$script" 2>&1
    ) &
    local pid=$!
    spinner $pid
    wait $pid
    local rc=$?
    [ $rc -ne 0 ] && msg "${RED}Хук завершился с кодом $rc${NC}"
  done
}

show_hooks() {
  msg "${GREEN}=== Установленные хуки ===${NC}"
  for event_dir in "$HOOKS_DIR/"*/; do
    [ -d "$event_dir" ] || continue
    local event=$(basename "$event_dir")
    msg "${CYAN}[$event]${NC}"
    for script in "$event_dir"/*; do
      [ -x "$script" ] && msg "  - $(basename "$script")"
    done
  done
}

ALLOWED_HOOK_EVENTS="pre-activate post-activate on-link-broken on-link-restored on-ota-detected pre-deactivate post-deactivate"
run_hooks_cmd() {
  local event="$1"
  local valid=0
  for e in $ALLOWED_HOOK_EVENTS; do
    [ "$e" = "$event" ] && valid=1
  done
  if [ $valid -eq 0 ]; then
    msg "${RED}Недопустимое событие: $event${NC}"
    msg "Допустимые события: $ALLOWED_HOOK_EVENTS"
    return 1
  fi
  run_event_hooks "$event" "$(cat "$MODDIR/.target_part" 2>/dev/null)" "$(get_active_loop boot)" ""
}

enable_module() {
  if [ -f "$DISABLE_FLAG" ]; then
    rm "$DISABLE_FLAG"
    msg "${GREEN}Модуль включён. Перезагрузите устройство.${NC}"
    log_action "enable"
  else
    msg "${YELLOW}Модуль уже включён.${NC}"
  fi
}

disable_module() {
  touch "$DISABLE_FLAG"
  run_event_hooks "pre-deactivate" "$(cat "$MODDIR/.target_part" 2>/dev/null)" "$(get_active_loop boot)" ""
  msg "${YELLOW}Модуль отключён. После перезагрузки будет неактивен.${NC}"
  run_event_hooks "post-deactivate" "$(cat "$MODDIR/.target_part" 2>/dev/null)" "$(get_active_loop boot)" ""
  log_action "disable"
}

restore_module() {
  if [ "$1" != "force" ]; then
    printf "Вы уверены, что хотите убрать подмену и отключить модуль? [y/N] "
    read confirm
    case "$confirm" in
      [Yy]|[Yy][Ee][Ss]) ;;
      *) msg "Отмена."; return 1 ;;
    esac
  fi
  local target=$(cat "$MODDIR/.target_part" 2>/dev/null)
  local loop=$(get_active_loop boot)
  run_event_hooks "pre-deactivate" "$target" "$loop" ""
  msg "${GREEN}Выполняется восстановление...${NC}"
  ( restore_actions ) &
  local pid=$!
  spinner $pid
  wait $pid
  local rc=$?
  if [ $rc -eq 0 ]; then
    msg "${YELLOW}Исходные ссылки восстановлены. Модуль отключён. Рекомендуется перезагрузка.${NC}"
    run_event_hooks "post-deactivate" "$target" "$loop" ""
    log_action "restore"
  else
    msg "${RED}Ошибка при восстановлении.${NC}"
  fi
}

restore_actions() {
  if [ -f "$MODDIR/.byname_dir" ]; then
    BYNAME_DIR=$(cat "$MODDIR/.byname_dir")
    if grep -q " $BYNAME_DIR " /proc/mounts 2>/dev/null; then
      umount "$BYNAME_DIR" 2>/dev/null
    fi
  fi
  for type in boot $EXTRA_PARTS; do
    local loop=$(get_active_loop "$type")
    if [ -n "$loop" ] && [ -b "$loop" ]; then
      safe_run 5 losetup -d "$loop" 2>/dev/null
    fi
  done
  rm -f "$MODDIR/.stock_checksum" "$MODDIR/.active_loop" "$MODDIR/.byname_dir" \
        "$MODDIR/.target_part" "$MODDIR/.vbmeta_enabled" "$MODDIR/.active_vbmeta_loop" \
        "$MODDIR/.vendor_boot_enabled" "$MODDIR/.active_vendor_boot_loop" \
        "$MODDIR/.recovery_enabled" "$MODDIR/.active_recovery_loop" \
        "$MODDIR/.dtbo_enabled" "$MODDIR/.active_dtbo_loop" \
        "$MODDIR/.last_check" "$MODDIR/.stock_size" "$MODDIR/.backing_file" \
        "$FREEZE_FLAG" "$STEALTH_FLAG" "$MONITOR_FLAG" "$WATCHDOG_PIDFILE" \
        "$RESTORE_COUNT_FILE" "$LOOP_ERROR_FILE"
  touch "$DISABLE_FLAG"
}

freeze_module() {
  if [ -f "$FREEZE_FLAG" ]; then
    msg "${YELLOW}Уже заморожен.${NC}"
  else
    local target=$(cat "$MODDIR/.target_part" 2>/dev/null)
    local loop=$(get_active_loop boot)
    run_event_hooks "pre-deactivate" "$target" "$loop" ""
    touch "$FREEZE_FLAG"
    if [ -f "$MODDIR/.byname_dir" ]; then
      local byname=$(cat "$MODDIR/.byname_dir")
      if grep -q " $byname " /proc/mounts 2>/dev/null; then
        umount "$byname" 2>/dev/null
      fi
    fi
    msg "${YELLOW}Модуль заморожен. Подмена отключена до разморозки.${NC}"
    run_event_hooks "post-deactivate" "$target" "$loop" ""
    log_action "freeze"
  fi
}

thaw_module() {
  if [ -f "$FREEZE_FLAG" ]; then
    rm -f "$FREEZE_FLAG"
    msg "${GREEN}Модуль разморожен. Подмена восстановлена.${NC}"
    /data/adb/modules/bootmask/post-fs-data.sh 2>/dev/null &
    log_action "thaw"
  else
    msg "${YELLOW}Не был заморожен.${NC}"
  fi
}

analyze() {
  echo -e "${GREEN}=== Анализатор состояния ===${NC}\n"
  local issues=0
  if [ -f "$DISABLE_FLAG" ]; then
    echo -e "${RED}[!] Модуль отключён.${NC}"
    issues=$((issues+1))
  else
    echo -e "${GREEN}[✓] Модуль включён.${NC}"
  fi
  if [ ! -f "$STOCK_PLAIN" ]; then
    echo -e "${RED}[!] Стоковый образ не найден.${NC}"
    issues=$((issues+1))
  else
    echo -e "${GREEN}[✓] Стоковый образ найден.${NC}"
  fi
  local loop=$(get_active_loop boot)
  if [ -z "$loop" ] || [ ! -b "$loop" ]; then
    echo -e "${RED}[!] Loop-устройство не активно.${NC}"
    issues=$((issues+1))
  else
    echo -e "${GREEN}[✓] Loop-устройство активно: $loop${NC}"
  fi
  if [ -f "$STOCK_PLAIN" ] && [ -b "$loop" ]; then
    local stock_size=$(stat -c%s "$STOCK_PLAIN")
    local loop_size=$(blockdev --getsize64 "$loop" 2>/dev/null)
    if [ -n "$loop_size" ] && [ "$stock_size" != "$loop_size" ]; then
      echo -e "${RED}[!] Размеры не совпадают.${NC}"
      issues=$((issues+1))
    else
      echo -e "${GREEN}[✓] Размеры совпадают.${NC}"
    fi
  fi
  if [ -f "$COMPAT_FLAG" ]; then
    echo -e "${YELLOW}[i] Compat mode активен.${NC}"
  else
    if [ -f "$MODDIR/.byname_dir" ]; then
      local byname=$(cat "$MODDIR/.byname_dir")
      if grep -q " $byname " /proc/mounts 2>/dev/null; then
        echo -e "${GREEN}[✓] tmpfs смонтирована.${NC}"
      else
        echo -e "${RED}[!] tmpfs не смонтирована.${NC}"
        issues=$((issues+1))
      fi
    fi
  fi
  [ -f "$FREEZE_FLAG" ] && echo -e "${YELLOW}[i] Модуль заморожен.${NC}"
  [ -f "$STEALTH_FLAG" ] && echo -e "${YELLOW}[i] Stealth активен.${NC}"
  [ -f "$MONITOR_FLAG" ] && echo -e "${YELLOW}[i] Monitor активен.${NC}"

  local restore_count=$(cat "$RESTORE_COUNT_FILE" 2>/dev/null)
  local loop_errors=$(cat "$LOOP_ERROR_FILE" 2>/dev/null)
  echo -e "${GREEN}[i] Статистика watchdog:${NC}"
  echo "    Восстановлений ссылок: $restore_count"
  echo "    Ошибок loop: $loop_errors"

  if [ -f "$MODDIR/bootmask.log" ]; then
    local last_restore=$(grep "restored" "$MODDIR/bootmask.log" 2>/dev/null | tail -1)
    [ -n "$last_restore" ] && echo "    Последнее восстановление: $last_restore"
    local last_error=$(grep "error\|FAILED" "$MODDIR/bootmask.log" 2>/dev/null | tail -1)
    [ -n "$last_error" ] && echo "    Последняя ошибка: $last_error"
  fi

  # Проверка соответствия образа текущей прошивке
  local fp_file="$MODDIR/.stock_fingerprint"
  if [ -f "$fp_file" ]; then
    local fp_saved=$(cat "$fp_file" 2>/dev/null | tr -d ' \t\r\n')
    local fp_current=$(getprop ro.build.fingerprint 2>/dev/null | tr -d ' \t\r\n')
    if [ -n "$fp_saved" ] && [ -n "$fp_current" ]; then
      if [ "$fp_saved" = "$fp_current" ]; then
        echo -e "${GREEN}[✓] stock_boot.img соответствует текущей прошивке.${NC}"
      else
        echo -e "${RED}[!] stock_boot.img от другой версии прошивки!${NC}"
        echo "    Установлен при: $fp_saved"
        echo "    Текущий:        $fp_current"
        echo "    Замените stock_boot.img и переустановите модуль."
        issues=$((issues+1))
      fi
    fi
  fi

  echo ""
  if [ $issues -eq 0 ]; then
    echo -e "${GREEN}=== Все проверки пройдены. ===${NC}"
  else
    echo -e "${RED}=== Обнаружено проблем: $issues ===${NC}"
  fi
}

analyze_json() {
  local target=$(cat "$MODDIR/.target_part" 2>/dev/null || echo "boot")
  local loop=$(get_active_loop boot)
  local disabled="false"; [ -f "$DISABLE_FLAG" ] && disabled="true"
  local compat="false"; [ -f "$COMPAT_FLAG" ] && compat="true"
  local tmpfs_mounted="false"
  if [ -f "$MODDIR/.byname_dir" ]; then
    local byname=$(cat "$MODDIR/.byname_dir")
    grep -q " $byname " /proc/mounts 2>/dev/null && tmpfs_mounted="true"
  fi
  local restore_count=$(cat "$RESTORE_COUNT_FILE" 2>/dev/null)
  local loop_errors=$(cat "$LOOP_ERROR_FILE" 2>/dev/null)

  echo "{"
  echo "  \"module\": \"${disabled}\","
  echo "  \"disabled\": ${disabled},"
  echo "  \"target\": \"${target}\","
  echo "  \"loop\": \"${loop:-null}\","
  echo "  \"compat_mode\": ${compat},"
  echo "  \"tmpfs_mounted\": ${tmpfs_mounted},"
  echo "  \"restore_count\": ${restore_count},"
  echo "  \"loop_errors\": ${loop_errors}"
  echo "}"
}

generate_report() {
  local report_dir="/sdcard/BootMask/reports"
  mkdir -p "$report_dir"
  local report_file="$report_dir/bootmask_report_$(date +%Y%m%d_%H%M%S).txt"

  # Временно обнуляем цвета, чтобы отчёт не содержал ANSI-последовательностей
  # (надёжнее, чем чистка через sed, и не зависит от реализации sed на устройстве)
  local _G="$GREEN" _R="$RED" _Y="$YELLOW" _C="$CYAN" _B="$BLUE" _M="$MAGENTA" _N="$NC"
  GREEN=''; RED=''; YELLOW=''; CYAN=''; BLUE=''; MAGENTA=''; NC=''

  {
    echo "=== Boot Integrity Mask Report ==="
    echo "Дата: $(date)"
    echo ""

    # Компактный статус (без clear/escape — show_dashboard в отчёт не зовём)
    echo "=== Статус модуля ==="
    echo "Состояние: $([ -f "$DISABLE_FLAG" ] && echo ОТКЛЮЧЁН || echo АКТИВЕН)"
    echo "Целевой раздел: $(cat "$MODDIR/.target_part" 2>/dev/null || echo boot)"
    echo "Loop-устройство: $(get_active_loop boot)"
    echo "Слот: $(getprop ro.boot.slot_suffix)"
    echo "Watchdog интервал: $(get_watchdog_interval)с"
    echo "Stealth: $([ -f "$STEALTH_FLAG" ] && echo ВКЛ || echo ВЫКЛ)"
    echo "Monitor: $([ -f "$MONITOR_FLAG" ] && echo ВКЛ || echo ВЫКЛ)"
    echo "Compat mode: $([ -f "$COMPAT_FLAG" ] && echo ВКЛ || echo ВЫКЛ)"
    echo "Freeze: $([ -f "$FREEZE_FLAG" ] && echo ВКЛ || echo ВЫКЛ)"
    echo ""

    # diag/hooks через tr -d '\033' — удаляем любые случайные ESC-символы
    show_diag | tr -d '\033'
    echo ""
    echo "=== Статистика watchdog ==="
    echo "Восстановлений ссылок: $(cat "$RESTORE_COUNT_FILE")"
    echo "Ошибок loop: $(cat "$LOOP_ERROR_FILE")"
    echo ""
    echo "=== Список хуков ==="
    show_hooks | tr -d '\033'
    echo ""
    echo "=== Состояние sysfs ==="
    [ -f /sys/class/power_supply/battery/capacity ] && echo "Батарея: $(cat /sys/class/power_supply/battery/capacity)%"
    [ -f /sys/class/thermal/thermal_zone0/temp ] && echo "Температура: $(( $(cat /sys/class/thermal/thermal_zone0/temp) / 1000 ))°C"
    [ -f /sys/devices/system/cpu/cpufreq/policy0/scaling_governor ] && echo "CPU governor: $(cat /sys/devices/system/cpu/cpufreq/policy0/scaling_governor)"
    echo ""

    # Журнал событий: dmesg (если доступен) + bootmask.log
    echo "=== Журнал событий ==="
    _dmesg_out=$(dmesg 2>/dev/null | grep BootMask | uniq)
    if [ -n "$_dmesg_out" ]; then
      echo "[ Логи ядра (dmesg) ]"
      echo "$_dmesg_out"
      echo ""
    else
      echo "[ Логи ядра (dmesg) недоступны — ограничение dmesg_restrict/SELinux или stealth-режим ]"
      echo ""
    fi
    if [ -f "$MODDIR/bootmask.log" ]; then
      echo "[ Журнал модуля (bootmask.log) ]"
      cat "$MODDIR/bootmask.log"
    else
      echo "[ Журнал модуля (bootmask.log) пуст или отсутствует ]"
    fi
  } > "$report_file"

  # Восстанавливаем цвета
  GREEN="$_G"; RED="$_R"; YELLOW="$_Y"; CYAN="$_C"; BLUE="$_B"; MAGENTA="$_M"; NC="$_N"

  msg "${GREEN}Отчёт сохранён: $report_file${NC}"
  log_action "report"
}

diff_report() {
  local report_dir="/sdcard/BootMask/reports"
  if [ ! -d "$report_dir" ]; then
    msg "${RED}Нет сохранённых отчётов.${NC}"
    return 1
  fi
  local last=$(ls -1t "$report_dir"/bootmask_report_*.txt 2>/dev/null | head -1)
  local prev=$(ls -1t "$report_dir"/bootmask_report_*.txt 2>/dev/null | head -2 | tail -1)
  if [ -z "$last" ] || [ -z "$prev" ]; then
    msg "${RED}Необходимо минимум два отчёта. Создайте их командой report.${NC}"
    return 1
  fi
  if ! command -v diff >/dev/null 2>&1; then
    msg "${RED}Утилита diff не найдена.${NC}"
    return 1
  fi
  msg "${GREEN}Сравнение отчётов:${NC}"
  msg "  Последний: $(basename "$last")"
  msg "  Предыдущий: $(basename "$prev")"
  msg ""
  diff -u "$prev" "$last" 2>/dev/null | while IFS= read -r line; do
    case "$line" in
      ---*) msg "${BLUE}$line${NC}" ;;
      +++*) msg "${BLUE}$line${NC}" ;;
      -*) msg "${RED}$line${NC}" ;;
      +*) msg "${GREEN}$line${NC}" ;;
      @@*) msg "${CYAN}$line${NC}" ;;
      *) msg "$line" ;;
    esac
  done
  log_action "diff-report"
}

